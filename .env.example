# Admin secret for data export and deletion
# Change this to a secure random string in production
ADMIN_SECRET=change-me-in-production

# Optional: call a remote API instead of local /api routes from browser clients.
# Leave empty for local development, or set for production API.
# Example: https://lausperte.vercel.app/api
NEXT_PUBLIC_API_BASE_URL=https://lausperte.vercel.app/api
DATABASE_URL=ABC